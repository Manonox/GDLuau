[sub_resource type="GDScript" id="GDScript_gxxnv"]
script/source = "extends Node


@onready var luau_vm : LuauVM = $LuauVM


func _ready():
	get_tree().create_timer(0.5).timeout.connect(func():
		print(\"Openning libraries...\")
		luau_vm.open_all_libraries()

		print(\"Running...\")
		
		luau_vm.do_string(\"\"\"
		
			function poop(a, b, c)
				return {
					c = c - 1,
					ba = b + a,
				}
			end
		
		\"\"\")
		
		luau_vm.getglobal(\"poop\")
		var poop_func := luau_vm.tofunction(-1)
		luau_vm.pop(1)

		print(poop_func.pcall(5, 3, 5.5))

		print(\"Finished.\")
		
		)


func _on_luau_vm_stdout(message: String):
	print(message)
"

